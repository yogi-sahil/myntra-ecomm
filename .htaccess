<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Route /api/* requests through PHP proxy to Node.js on port 8999
  # (mod_proxy not available on Hostinger shared hosting)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} ^/api
  RewriteRule ^(.*)$ /api-proxy.php [L,QSA]

  # Handle React Single Page Application (SPA) routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api
  RewriteRule . /index.html [L]
</IfModule>
